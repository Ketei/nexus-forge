func random_base64() -> String:
	var crypto := Crypto.new()
	var random_array: PackedByteArray = var_to_bytes(Time.get_unix_time_from_system())  # := crypto.generate_random_bytes(36)
	
	random_array.append_array(crypto.generate_random_bytes(3))
	
	return Marshalls.raw_to_base64(random_array).replace(\"+\", \"-\").replace(\"/\", \"_\")
